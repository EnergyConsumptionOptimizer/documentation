                        "readAt": {
                          "type": "string",
                          "nullable": true
                        },
                        "isRead": {
                          "type": "boolean"
                        },
                        "details": {
                          "type": "object",
                          "properties": {
                            "utility": {
                              "type": "string"
                            },
                            "limit": {
                              "type": "number"
                            },
                            "detected": {
                              "type": "number"
                            },
                            "thresholdName": {
                              "type": "string"
                            },
                            "periodType": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "utility",
                            "limit",
                            "detected",
                            "thresholdName"
                          ]
                        }
                      },
                      "required": [
                        "id",
                        "status",
                        "message",
                        "createdAt",
                        "sentAt",
                        "failReason",
                        "readAt",
                        "isRead",
                        "details"
                      ]
                    }
                  },
                  "required": [
                    "success",
                    "data"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "success",
                    "error"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Alert not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "success",
                    "error"
                  ]
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Alerts"
        ],
        "summary": "Update alert read state",
        "description": "Updates the read state of a specific alert.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
