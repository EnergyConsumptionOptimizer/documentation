{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "Alert Service API",
    "description": "API documentation for Alert Service microservice"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "security": [
    {
      "cookieAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "authToken"
      }
    },
    "schemas": {},
    "parameters": {}
  },
  "paths": {
    "/api/internal/alerts": {
      "post": {
        "tags": [
          "Internal - Alerts"
        ],
        "summary": "Create a new alert (internal endpoint)",
        "security": [

        ],
        "description": "Creates and sends a new alert. May suppress alert if spam mitigation policy applies.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "thresholdId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "thresholdName": {
                    "type": "string",
                    "minLength": 1
                  },
                  "utilityType": {
                    "type": "string",
                    "minLength": 1
                  },
                  "thresholdType": {
                    "type": "string",
                    "minLength": 1
                  },
                  "periodType": {
                    "type": "string"
                  },
                  "limitValue": {
                    "type": "number"
                  },
                  "detectedValue": {
                    "type": "number"
                  }
                },
                "required": [
                  "thresholdId",
                  "thresholdName",
                  "utilityType",
                  "thresholdType",
                  "limitValue",
                  "detectedValue"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Alert suppressed by spam mitigation policy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "success",
                    "message"
                  ]
                }
              }
            }
          },
          "201": {
            "description": "Alert created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "id"
                      ]
                    }
                  },
                  "required": [
                    "success",
                    "data"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "success",
                    "error"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/alerts": {
      "get": {
        "tags": [
          "Alerts"
        ],
        "summary": "Get all alerts",
        "description": "Retrieves all alerts for the authenticated user.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved alerts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "status": {
                            "type": "string",
                            "enum": [
                              "PENDING",
                              "SENT",
                              "FAILED"
                            ]
                          },
                          "message": {
                            "type": "string"
                          },
                          "createdAt": {
                            "type": "string"
                          },
                          "sentAt": {
                            "type": "string",
                            "nullable": true
                          },
                          "failReason": {
                            "type": "string",
                            "nullable": true
                          },
                          "readAt": {
                            "type": "string",
                            "nullable": true
                          },
                          "isRead": {
                            "type": "boolean"
                          },
                          "details": {
                            "type": "object",
                            "properties": {
                              "utility": {
                                "type": "string"
                              },
                              "limit": {
                                "type": "number"
                              },
                              "detected": {
                                "type": "number"
                              },
                              "thresholdName": {
                                "type": "string"
                              },
                              "periodType": {
                                "type": "string"
                              }
                            },
                            "required": [
                              "utility",
                              "limit",
                              "detected",
                              "thresholdName"
                            ]
                          }
                        },
                        "required": [
                          "id",
                          "status",
                          "message",
                          "createdAt",
                          "sentAt",
                          "failReason",
                          "readAt",
                          "isRead",
                          "details"
                        ]
                      }
                    }
                  },
                  "required": [
                    "success",
                    "data"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "success",
                    "error"
                  ]
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Alerts"
        ],
        "summary": "Delete all alerts (admin only)",
        "description": "Deletes all alerts in the system. Requires admin privileges.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "All alerts deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "success"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Admin authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "success",
                    "error"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/alerts/{id}": {
      "get": {
        "tags": [
